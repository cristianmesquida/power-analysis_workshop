labelnames = c("Intervention",
"HIIT", "Standard",
"Time",
"pre", "post6", "post8"),
plot = TRUE)
design_result <- ANOVA_design(
design = "2b*3w",
n = 80,
mu = c(120, 140, 140, 120, 130, 130),
sd = 10,
r <- 0.8,                # common correlation
labelnames = c("Intervention",
"HIIT", "Standard",
"Time",
"pre", "post6", "post8"),
plot = TRUE)
res <- ANOVA_exact(
design_result,
alpha_level = 0.05,
emm = TRUE
)
res$emmeans
comparisons <- emmeans(
res$emmeans$emmeans,
specs = ~ Intervention
)
custom_contrast <- contrast(
comparisons,
list(contrast_post6 = c(0, 1, 0,   # HIIT (post6)
0, -1, 0   # Standard (post6)
))
)
emm_results <- res$emmeans$emmeans
pairwise_results <- emmeans(
emm_results,
pairwise ~ Intervention | Time
)
pairwise_results
emmeans_power(pairwise_results)
emmeans_power(pairwise_results$contrasts)
