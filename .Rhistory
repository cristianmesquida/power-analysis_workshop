power_estimates <- map_dbl(n_seq, function(nsize) {
power_t_TOST(
n = nsize,
delta = d,
sd = sd,
low_eqbound = low,
high_eqbound = high,
alpha = 0.05,
type = type
)$power
})
# Combine into data frame
